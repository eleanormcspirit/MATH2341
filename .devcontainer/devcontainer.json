{
  "name": "MATH 2341 PreTeXt",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/git-lfs:1": {}
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y texlive-xetex texlive-pictures && bash .devcontainer/setup-pretext.sh",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:${containerEnv:HOME}/.local/bin"
  },
  "forwardPorts": [8000],
  "customizations": {
    "vscode": {
      "extensions": [
        "oscarlevin.pretext-tools",
        "redhat.vscode-xml"
      ],
      "settings": {
        "editor.wordWrap": "on",
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.minimap.enabled": false,
        "editor.guides.indentation": true,
        "editor.bracketPairColorization.enabled": true,
        "editor.tabCompletion": "onlySnippets",
        "[xml]": {
          "editor.formatOnSave": true,
          "editor.tabSize": 2
        }
      }
    }
  }
}