<?xml version="1.0" encoding="UTF-8"?>
<publication>
  <source>
    <directories external="../assets" generated="../generated-assets" />
  </source>

  <html>
    <platform host="web" />
    <css theme="default-modern"
         primary-color="#154734"
         secondary-color="#BD8B13"
         color-meta="#154734" />
    <!--
      If your PreTeXt CLI supports extra CSS through the publication file,
      point it to ../assets/css/math2341.css. If not, keep this file as a
      custom stylesheet to copy into the generated HTML assets.
    -->
  </html>
</publication>
