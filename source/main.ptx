    <chapter xml:id="course-notes">
      <title>Weekly Course Notes</title>
      <introduction>
        <p>
          These sections contain the main exposition for each week: definitions,
          examples, theorems, computational tools, and worked problems.
        </p>
      </introduction>
      <xi:include href="notes/week-01.ptx" />
    </chapter>

    <chapter xml:id="in-class-activities">
      <title>Weekly In-Class Activities</title>
      <introduction>
        <p>
          These activities are designed for collaborative work during class.
          They should be short, purposeful, and closely tied to the week&apos;s notes.
        </p>
      </introduction>
      <xi:include href="activities/week-01.ptx" />
    </chapter>

    <chapter xml:id="problem-sets">
      <title>Weekly Problem Sets</title>
