<?xml version="1.0" encoding="UTF-8"?>
<project ptx-version="2" source="source" output-dir="output">
  <targets>
    <target
      name="web"
      format="html"
      source="main.ptx"
      publication="../publication/publication.ptx"
      output-dir="web" />
    <target
      name="print"
      format="pdf"
      source="main.ptx"
      publication="../publication/publication.ptx"
      output-dir="print" />
  </targets>
</project>
